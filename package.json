{
  "name": "bushwick-maps",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3100 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "maplibre-gl": "^5.1.1",
    "motion": "^12.6.3",
    "next": "^15.3.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-map-gl": "^8.0.3",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "packageManager": "pnpm@10.24.0"
}
